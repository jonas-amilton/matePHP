{
  "name": "matephp/framework",
  "description": "Mini framework PHP para APIs REST.",
  "autoload": {
    "psr-4": {
      "App\\": "app/",
      "Framework\\": "framework/",
      "Database\\": "database/",
      "Database\\Seeders\\": "database/seeders/"
    },
    "files": [
      "framework/helpers/log.php"
    ]
  },
  "autoload-dev": {
    "psr-4": {
      "Tests\\": "tests/"
    }
  },
  "require": {
    "php": ">=8.0"
  },
  "scripts": {
    "phpunit": "phpunit --colors=always",
    "test": "@phpunit",
    "post-autoload-dump": [
      "@php -r \"echo 'Autoload updated successfully!';\""
    ]
  },
  "require-dev": {
    "phpunit/phpunit": "^12"
  }
}
